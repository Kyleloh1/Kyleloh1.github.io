---
// src/pages/teaching.astro
import Layout from '../layouts/Layout.astro';
---
<Layout title="Teaching — Kyle Loh">
  <section id="teaching">
    <h2>Teaching</h2>

    <h3>Kyle Loh's Math (YouTube)</h3>
    <p>I run a YouTube channel with math tutorials. Here's one video you might like:</p>

    <div class="video-wrapper">
      <iframe
        src="https://www.youtube.com/embed/wPaA1QblObs"
        title="Spotlight video"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen>
      </iframe>
    </div>

    <a class="btn" href="https://www.youtube.com/channel/UC_G7YxEksu7C9z5A08fdv7g" target="_blank" rel="noopener">
      Visit my YouTube channel →
    </a>

    <h3 style="margin-top:4.0rem; margin-bottom:1.25rem">Tutoring Resources</h3>
    <article class="card">
      <div class="card-body">
        <h3><a href="https://github.com/Kyleloh1/FAUHS-Biology-Notes" target="_blank" rel="noopener">FAUHS Biology Notes</a></h3>
        <p>A complete set of 9th-grade biology notes I wrote and used while tutoring students.</p>
        <div class="tags">
          <a class="tag tag-code" href="https://github.com/Kyleloh1/FAUHS-Biology-Notes" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </article>
  </section>
</Layout>